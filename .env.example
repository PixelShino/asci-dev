# =============================================================================
# Пример конфигурации окружения
# -----------------------------------------------------------------------------
# 1. Скопируйте этот файл в `.env.local`:   cp .env.example .env.local
# 2. Подставьте свои значения вместо плейсхолдеров.
# Файл `.env.local` игнорируется Git — реальные секреты в репозиторий не попадают.
# =============================================================================

# -----------------------------------------------------------------------------
# Почта — форма обратной связи (Nodemailer SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST="smtp.example.com"          # SMTP-хост вашего почтового провайдера
SMTP_PORT=465                          # 465 → SSL (secure); 587 → STARTTLS
SMTP_USER="user@example.com"           # логин SMTP (обычно email)
SMTP_PASS="your_smtp_password"         # пароль или app-password
OWNER_EMAIL="owner@example.com"        # email получателя заявок с формы

# -----------------------------------------------------------------------------
# AI-ассистент
# -----------------------------------------------------------------------------
GEMINI_API_KEY="your_gemini_api_key"           # Google AI Studio → API keys (gemini-2.5-flash)
OPENROUTER_API_KEY="your_openrouter_api_key"    # openrouter.ai → Keys (фоллбек: deepseek-chat)

# -----------------------------------------------------------------------------
# База данных — PostgreSQL (например, Neon)
# Формат: postgresql://<user>:<password>@<host>/<database>?sslmode=require
# -----------------------------------------------------------------------------
# Pooled-соединение (через pgbouncer) — для рантайма/serverless:
DATABASE_URL="postgresql://user:password@host-pooler.region.example.tech/dbname?sslmode=require"
# Direct-соединение (без пула) — для миграций:
DATABASE_URL_UNPOOLED="postgresql://user:password@host.region.example.tech/dbname?sslmode=require"

# -----------------------------------------------------------------------------
# Payload CMS
# -----------------------------------------------------------------------------
# Случайная секретная строка для подписи токенов. Сгенерировать, например:
#   openssl rand -base64 32
PAYLOAD_SECRET="generate_a_long_random_string"

# -----------------------------------------------------------------------------
# Хранилище медиа — Vercel Blob
# Токен: Vercel Dashboard → Storage → Blob → Connect (создаётся автоматически)
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxx"
